{
  "name": "sleeper-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo: sleeper-web (PWA) + sleeper-machine (Galland) + sleeper-machine-kotki.",
  "scripts": {
    "test": "pnpm --filter sleeper-machine test",
    "build": "pnpm --filter sleeper-machine build",
    "machine-kotki:test": "pnpm --filter sleeper-machine-kotki test",
    "machine-kotki:build": "pnpm --filter sleeper-machine-kotki build",
    "web:dev": "pnpm --filter sleeper-web start --web",
    "web:build": "pnpm --filter sleeper-web build",
    "web:build:check": "pnpm --filter sleeper-web build:check",
    "web:typecheck": "pnpm --filter sleeper-web exec tsc --noEmit",
    "web:lint": "pnpm --filter sleeper-web lint",
    "web:test": "pnpm --filter sleeper-web test"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.1"
}
