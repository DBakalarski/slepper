{
  "name": "sleeper-machine",
  "version": "0.1.0",
  "type": "module",
  "description": "Algorithm for recommending infant/toddler sleep timing based on Galland 2012 baseline + adaptive personalization.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "smoke": "tsx scripts/smoke-test.ts",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "files": [
    "dist",
    "src",
    "USAGE.md"
  ],
  "keywords": [
    "sleep",
    "infant",
    "toddler",
    "baby",
    "nap",
    "schedule",
    "algorithm",
    "galland",
    "react-native",
    "expo"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^3.2.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
