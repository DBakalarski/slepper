{
  "name": "sleeper-machine-kotki",
  "version": "0.1.0",
  "type": "module",
  "description": "Lookup-based sleep schedule algorithm for infants based on Kotki Dwa guidebook methodology.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "sleeper-machine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  }
}
