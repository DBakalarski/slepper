{
  "expo": {
    "name": "Sleeper",
    "slug": "sleeper-web",
    "version": "0.1.0",
    "scheme": "sleeperweb",
    "userInterfaceStyle": "automatic",
    "platforms": ["web"],
    "web": {
      "output": "single",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
