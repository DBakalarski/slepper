{
  "expo": {
    "name": "Sleeper",
    "slug": "sleeper-web",
    "version": "0.6.0",
    "scheme": "sleeperweb",
    "userInterfaceStyle": "automatic",
    "platforms": ["web"],
    "web": {
      "output": "single",
      "bundler": "metro",
      "lang": "pl",
      "themeColor": "#208AEF",
      "description": "Trackuj sen i okna aktywnosci dziecka. Synchronizacja miedzy urzadzeniami."
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
